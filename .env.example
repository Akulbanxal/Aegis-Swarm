# ─────────────────────────────────────────────────────────────
# AEGIS SWARM — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ─── Somnia Network ──────────────────────────────────────────
SOMNIA_TESTNET_RPC_URL=https://dream-rpc.somnia.network
SOMNIA_TESTNET_WS_URL=wss://dream-rpc.somnia.network
SOMNIA_TESTNET_CHAIN_ID=50312
SOMNIA_MAINNET_RPC_URL=https://mainnet-rpc.somnia.network
SOMNIA_MAINNET_CHAIN_ID=5031

# ─── Deployer Wallet ─────────────────────────────────────────
# Private key of the deployer wallet (DO NOT USE MAINNET KEY IN DEV)
DEPLOYER_PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...

# ─── Deployed Contract Addresses (filled after deployment) ───
AEGIS_CORE_ADDRESS=
AEGIS_TREASURY_ADDRESS=
THREAT_REGISTRY_ADDRESS=
ALERT_REGISTRY_ADDRESS=
VAULT_GUARD_ADDRESS=
AEGIS_GOVERNANCE_ADDRESS=

# ─── Somnia Agent IDs (from docs.somnia.network/agents) ──────
SENTINEL_AGENT_ID=
ANALYST_AGENT_ID=
RESPONDER_AGENT_ID=
ARCHIVIST_AGENT_ID=
MESSENGER_AGENT_ID=
SOMNIA_AGENT_ROUTER_ADDRESS=

# ─── Aegis Backend API ───────────────────────────────────────
BACKEND_PORT=3001
BACKEND_HOST=localhost

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegis_swarm
REDIS_URL=redis://localhost:6379

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_SOMNIA_RPC_URL=https://dream-rpc.somnia.network
NEXT_PUBLIC_SOMNIA_CHAIN_ID=50312
NEXT_PUBLIC_AEGIS_CORE_ADDRESS=
NEXT_PUBLIC_ALERT_REGISTRY_ADDRESS=
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ─── Threat Intelligence APIs ────────────────────────────────
# These are used by the Sentinel agent aggregator service
ETHERSCAN_API_KEY=
DEFIHACKLABS_API_KEY=

# ─── Alert Channels (used by Messenger agent) ────────────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PAGERDUTY_ROUTING_KEY=

# ─── Block Explorer ──────────────────────────────────────────
SOMNIA_EXPLORER_URL=https://shannon-explorer.somnia.network
SOMNIA_EXPLORER_API_KEY=
