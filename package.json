{
  "name": "aegis-swarm",
  "version": "1.0.0",
  "description": "Autonomous multi-agent smart contract defense system built on Somnia Agentic L1",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "agents",
    "tests"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "typecheck": "turbo typecheck",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test",
    "contracts:deploy": "cd contracts && forge script script/Deploy.s.sol",
    "setup": "npm install && npm run contracts:build",
    "demo": "npx tsx scripts/demo.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.6.1"
}